# ── Firebase Config (obténlos en Firebase Console → Configuración del proyecto) ──
NEXT_PUBLIC_FIREBASE_API_KEY=AIza...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=cajachica-flow.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=cajachica-flow
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=cajachica-flow.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abc123

# ── Estos van en GitHub Secrets (NO en el código) ──────────────
# FIREBASE_SERVICE_ACCOUNT → JSON de cuenta de servicio Firebase
# FIREBASE_API_KEY → igual a NEXT_PUBLIC_FIREBASE_API_KEY
# FIREBASE_AUTH_DOMAIN → igual a NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN
# FIREBASE_PROJECT_ID → cajachica-flow
# FIREBASE_STORAGE_BUCKET → cajachica-flow.appspot.com
# FIREBASE_MESSAGING_SENDER_ID → número del proyecto
# FIREBASE_APP_ID → ID de la app web
